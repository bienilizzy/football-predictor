# football-data.org API key (free tier) - register at https://www.football-data.org/client/register
# Used only to fetch the upcoming fixture schedule (dates/kickoff times).
FOOTBALL_DATA_ORG_API_KEY=

# Sportmonks API key (free tier covers football, cricket, F1, tennis) -
# register at https://www.sportmonks.com/. Used by the multi-sport data
# layer (src/football_predictor/sports/data_layer.py); football falls back
# to football-data.org if a Sportmonks request fails.
SPORTMONKS_API_KEY=...
SPORTMONKS_TIER=basic

# Sportscore API key (RapidAPI) - used by sports/sportscore_client.py for
# fixture and live-event data across sports (football, basketball, etc.).
# Get a key at https://rapidapi.com/tipsters/api/sportscore1
SPORTSCORE_API_KEY=

# Anthropic API key - register at https://console.anthropic.com/. Used by the
# LLM analyst committee (src/football_predictor/agents/committee.py) for the
# elite-tier `/predictions/llm` and `/sports/{sport}/upcoming` endpoints.
# Falls back to the SDK's own ANTHROPIC_API_KEY environment variable lookup
# if left blank here.
ANTHROPIC_API_KEY=sk-...

# Optional fallback LLM provider key. Not currently called by the analyst
# committee (which is Anthropic-only) - reserved for a future fallback path
# if the Anthropic API is unavailable.
OPENAI_API_KEY=optional_fallback

# Redis connection URL, used to cache LLM analyst-committee responses
# (src/football_predictor/agents/cache.py). A repeat prediction for the same
# fixture + sport within 1 hour is served from the cache instead of
# re-querying the committee. `docker compose up redis` runs a local instance
# on localhost:6379; when the API itself runs via docker-compose this is
# overridden to redis://redis:6379/0 to reach the `redis` service by name.
REDIS_URL=redis://localhost:6379/0

# Database (SQLite by default, swap to a Postgres URL later if needed).
# The `?uri=true&nolock=1` suffix is required for SQLite to work on
# network-mounted filesystems (e.g. WSL paths accessed from Windows); it's
# harmless on a local disk too. Drop it if you're on a normal local path
# and want full SQLite locking guarantees for concurrent writers.
DATABASE_URL=sqlite:///file:./data/football_predictor.db?uri=true&nolock=1

# Local storage paths
DATA_RAW_DIR=./data/raw
MODEL_DIR=./models

# League identifiers across the three data sources
FD_ORG_COMPETITION_CODE=PL
FD_CO_UK_LEAGUE_CODE=E0
UNDERSTAT_LEAGUE=EPL

# Seasons to backfill historically, as football-data.co.uk season codes
# (e.g. 2223 = 2022-23, 2324 = 2023-24, 2425 = 2024-25)
HISTORICAL_SEASONS=2223,2324,2425

# Current season label (used for fixtures/predictions), e.g. 2025-2026
CURRENT_SEASON=2025-2026
